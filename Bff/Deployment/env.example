# Skopiuj do deployment.env i uzupełnij wartości:
#   cp env.example deployment.env
#
# Ten plik jest wczytywany przez build-image.sh i deploy.sh (bash source).
# Zmienne IMAGE_*, CONTAINER_NAME są tylko dla skryptów deploy.
# HOST_PORT — tylko komunikat po deployu; z --network host nasłuch jest wg ASPNETCORE_URLS.

# --- obraz Docker ---
IMAGE_NAME=wordki-bff
IMAGE_TAG=latest

# --- uruchomienie kontenera (deploy / docker-compose) ---
CONTAINER_NAME=wordki-bff
# docker-compose mapuje HOST_PORT:5000 (na macOS często 5001 — AirPlay zajmuje 5000).
HOST_PORT=5000

# --- ASP.NET Core ---
ASPNETCORE_ENVIRONMENT=Production
# Port wewnątrz kontenera (Dockerfile). Publiczny port hosta = wpis „ports” w compose.
ASPNETCORE_URLS=http://+:5000

# --- PostgreSQL (format: Host=...;Port=5432;Database=...;Username=...;Password=...) ---
Urls=http://+:5000
ConnectionStrings__UsersDatabase=Host=postgres;Port=5432;Database=wordki;Username=wordki;Password=changeme
ConnectionStrings__CardsDatabase=Host=postgres;Port=5432;Database=wordki;Username=wordki;Password=changeme
ConnectionStrings__LessonsDatabase=Host=postgres;Port=5432;Database=wordki;Username=wordki;Password=changeme
ConnectionStrings__MigrationDatabase=Host=postgres;Port=5432;Database=wordki;Username=wordki;Password=changeme

# Publiczny URL API (linki w mailach potwierdzających) — ustaw na adres, pod którym klient widzi BFF.
Users__EmailConfirmation__ConfirmationUrlBase=https://api.example.com/api/users/confirm

# --- CORS (origin frontendu wywołującego BFF) ---
# Dodaj kolejne originy jako:
#   Cors__AllowedOrigins__1=https://twoj-drugi-origin.example.com
Cors__AllowedOrigins__0=https://wordki.example.com

# --- Seq (opcjonalnie; puste ServerUrl = wyłączone) ---
Seq__ServerUrl=
Seq__ApiKey=

AllowedHosts=*
