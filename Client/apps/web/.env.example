# Copy this file to `.env` — Vite does NOT read `.env.example`.
#
# Option A (recommended for local dev): omit VITE_BFF_BASE_URL or leave it empty.
# Requests go to the same origin as the dev server; Vite proxies `/api` → http://localhost:5000
# (see vite.config.ts). BFF must be running on port 5000.
#
# Option B: point the browser straight at the BFF (needs CORS; enabled in Development on the API).
# VITE_BFF_BASE_URL=http://localhost:5000

# Existing user id in cards.users (for testing GET /api/cards/groups)
VITE_DEV_USER_ID=00000000-0000-0000-0000-000000000000
