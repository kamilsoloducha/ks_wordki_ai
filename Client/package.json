{
  "name": "wordki-client",
  "private": true,
  "description": "Monorepo: Vite (web) + Expo (mobile) + wspólny pakiet @wordki/shared",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w web",
    "build:web": "npm run build -w web",
    "dev:mobile": "npm run start -w mobile",
    "android": "npm run android -w mobile",
    "typecheck:shared": "npm run typecheck -w @wordki/shared"
  }
}
